{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": [
    "kubectl@latest",
    "kubectx@latest",
    "kubernetes-helm@latest",
    "kind@latest",
    "uv@latest",
    "go-task@latest",
    "envsubst@latest",
    "act@latest",
    "yq-go@latest"
  ],
  "shell": {
    "init_hook": [
      "export GOBIN=$(git rev-parse --show-toplevel)/bin",
      "export PATH=$GOBIN:$PATH"
    ],
    "scripts": {
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
